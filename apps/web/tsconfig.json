{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "rootDirs": ["."],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@modules/*": ["./src/modules/*"],
      "@employees/*": ["./src/modules/employees/*"],
      "@teams/*": ["./src/modules/teams/*"],
      "@auth/*": ["./src/modules/auth/*"],
      "@inventory/*": ["./src/modules/inventory/*"],
      "@shared/*": ["./src/modules/shared/*"],
      "@organizations/*": ["./src/modules/organizations/*"],
    },
  },
}
