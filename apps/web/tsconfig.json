{
  "extends": "@fludge/config/tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "rootDir": "src",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "declaration": true,
    "declarationMap": true,
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "noEmit": false,
    "paths": {
      "@/*": ["./src/*"],
      "@fludge/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "src/routeTree.gen.ts"]
}
