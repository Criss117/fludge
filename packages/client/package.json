{
  "name": "@fludge/client",
  "type": "module",
  "exports": {
    "./providers/*": {
      "types": "./dist/providers/*.d.ts",
      "default": "./src/providers/*.tsx"
    },
    "./presentation/*": {
      "types": "./dist/presentation/*.d.ts",
      "default": "./src/presentation/*.tsx"
    },
    "./application/*": {
      "types": "./dist/application/*.d.ts",
      "default": "./src/application/*.ts"
    }
  },
  "scripts": {},
  "dependencies": {
    "@fludge/api": "workspace:*",
    "@fludge/auth": "workspace:*",
    "@fludge/ui": "workspace:*",
    "@fludge/utils": "workspace:*",
    "@orpc/client": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/tanstack-query": "catalog:",
    "@tanstack/query-db-collection": "catalog:",
    "@tanstack/react-db": "catalog:",
    "@tanstack/react-form": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-table": "catalog:",
    "better-auth": "catalog:",
    "react": "catalog:",
    "zod": "catalog:",
    "lucide-react": "catalog:"
  },
  "devDependencies": {
    "@fludge/config": "workspace:*",
    "typescript": "catalog:",
    "@types/react": "catalog:"
  }
}
