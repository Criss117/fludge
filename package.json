{
  "name": "fludge",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "elysia": "^1.4.28",
      "@orpc/server": "^1.13.14",
      "@orpc/openapi": "^1.13.14",
      "@orpc/zod": "^1.13.14",
      "better-auth": "1.6.11",
      "next-themes": "^0.4.6",
      "@orpc/tanstack-query": "^1.13.14",
      "@orpc/client": "^1.13.14",
      "@tanstack/react-query": "^5.90.12",
      "@tanstack/react-form": "^1.28.0",
      "@types/react-dom": "^19.2.3",
      "@better-auth/expo": "1.6.11"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @fludge/db db:push",
    "db:studio": "turbo -F @fludge/db db:studio",
    "db:generate": "turbo -F @fludge/db db:generate",
    "db:migrate": "turbo -F @fludge/db db:migrate",
    "db:start": "turbo -F @fludge/db db:start",
    "db:watch": "turbo -F @fludge/db db:watch",
    "db:stop": "turbo -F @fludge/db db:stop",
    "db:down": "turbo -F @fludge/db db:down"
  },
  "dependencies": {
    "@fludge/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@fludge/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.14"
}
